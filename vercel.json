{
  "rewrites": [
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch-ig-metrics",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/fetch-yt-metrics",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/fetch-tiktok-metrics",
      "schedule": "0 5 * * *"
    }
  ]
}
