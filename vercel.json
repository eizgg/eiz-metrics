{
  "rewrites": [
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch-ig-metrics",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/fetch-yt-metrics",
      "schedule": "0 3,9,15,21 * * *"
    },
    {
      "path": "/api/cron/fetch-tiktok-metrics",
      "schedule": "0 1,7,13,19 * * *"
    }
  ]
}
